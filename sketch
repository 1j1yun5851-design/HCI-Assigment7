// ── 입력: 드래그=시간, 탭=한시 ─────────────────────────────────────────
function mousePressed(){ pressX=mouseX;pressY=mouseY;pressT=millis();dragging=false;dayAtPress=dayPhase; }
function mouseDragged(){
  if(Math.abs(mouseY-pressY)>6) dragging=true;
  if(dragging) dayPhase=constrain(dayAtPress - (mouseY-pressY)/(H*0.9),0,1);
}
function mouseReleased(){
  const moved=Math.hypot(mouseX-pressX,mouseY-pressY);
  const quick=millis()-pressT<450;
  if(!dragging && moved<8 && quick) tap(mouseX,mouseY);
}
function touchStarted(){ mousePressed(); return false; }
function touchMoved(){ mouseDragged(); return false; }
function touchEnded(){ mouseReleased(); return false; }

function tap(x,y){
  if(millis()-lastSummon<600) return;
  lastSummon=millis();
  blooms.push({x,y,r:8,vr:1.6,a:1});
  for(const p of petals){ p.vy*=1.4; }
  if(cranes.length){ const c=random(cranes); c.x=x;c.y=y;c.sp=(x<W/2)?Math.abs(c.sp):-Math.abs(c.sp); }
  summonVerse();
}

async function summonVerse(){
  verse.loading=true; verse.active=false; verse.error='';
  const lab = dayPhase<0.33?'새벽 안개 속':dayPhase<0.66?'한낮의 맑은 빛 아래':'황혼이 물드는 하늘 아래';
  const sys =
    '너는 구름 속에 사는 신선이다. 흐릿한 해, 첩첩 수묵 산, 피어오르는 운무, 백학, 복사꽃, ' +
    '물에 비친 풍경을 보고 짧은 한시 한 수를 읊는다. 5언 또는 7언 두 구(두 줄)로 고요하고 ' +
    '그윽하게 짓되, 유명한 옛 시구를 그대로 베끼지 말고 새로 지어라. 반드시 아래 JSON 형식만 ' +
    '출력한다. 마크다운·설명·백틱 금지.\n' +
    '{"hanja":["○○○○○","○○○○○"],"korean":"첫 구 뜻 / 둘째 구 뜻"}';
  const usr = '지금은 '+lab+'. 한시 한 수를 청합니다.';

  let got=null;
  try{
    const res=await fetch(API_ENDPOINT,{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ model:'claude-sonnet-4-6', max_tokens:1000,
        system:sys, messages:[{role:'user',content:usr}] }),
    });
    if(!res.ok) throw new Error('HTTP '+res.status);
    const data=await res.json();
    const txt=(data.content||[]).map(b=>b.type==='text'?b.text:'').join('').trim();
    const clean=txt.replace(/```json|```/g,'').trim();
    const s=clean.indexOf('{'), e=clean.lastIndexOf('}');
    const parsed=JSON.parse(clean.slice(s,e+1));
    if(Array.isArray(parsed.hanja)&&parsed.hanja.length>=1&&
       parsed.hanja.every(v=>typeof v==='string'&&v.length))
      got={hanja:parsed.hanja.slice(0,3),korean:parsed.korean||'',ai:true};
  }catch(err){ verse.error='API 연결 안 됨'; }

  if(!got){ const f=FALLBACK[Math.floor(random(FALLBACK.length))]; got={hanja:f.hanja,korean:f.korean,ai:false}; }
  verse.hanja=got.hanja; verse.korean=got.korean; verse.fromAI=got.ai;
  verse.loading=false; verse.active=true; verse.revealAt=millis();
}

// ── 유틸 ────────────────────────────────────────────────────────────────
function makeSoftCircle(size,col){
  const g=createGraphics(size,size); const ctx=g.drawingContext;
  const grd=ctx.createRadialGradient(size/2,size/2,0,size/2,size/2,size/2);
  grd.addColorStop(0,rgba(col,0.95)); grd.addColorStop(0.45,rgba(col,0.5)); grd.addColorStop(1,rgba(col,0));
  ctx.fillStyle=grd; ctx.fillRect(0,0,size,size); return g;
}
function makeGrain(size){
  const g=createGraphics(size,size); g.loadPixels();
  for(let i=0;i<g.pixels.length;i+=4){ const v=200+Math.random()*55;
    g.pixels[i]=v; g.pixels[i+1]=v; g.pixels[i+2]=v; g.pixels[i+3]=255; }
  g.updatePixels(); return g;
}
function rgb(c){ return `rgb(${c[0]|0},${c[1]|0},${c[2]|0})`; }
function rgba(c,a){ return `rgba(${c[0]|0},${c[1]|0},${c[2]|0},${a})`; }
function rgbaArr(c,a){ return color(c[0],c[1],c[2],a*255); }
function shade(c,d){ return [constrain(c[0]+d,0,255),constrain(c[1]+d,0,255),constrain(c[2]+d,0,255)]; }
function lerpC(a,b,f){ return [lerp(a[0],b[0],f),lerp(a[1],b[1],f),lerp(a[2],b[2],f)]; }
